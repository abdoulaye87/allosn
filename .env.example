# ===========================================
# AlloSN - Variables d'environnement
# ===========================================

# Base de données
# Pour le développement local (SQLite)
DATABASE_URL="file:./db/custom.db"

# Pour la production (PostgreSQL - Supabase, Neon, etc.)
# Décommenter et remplacer par votre URL
# DATABASE_URL="postgresql://user:password@host:5432/allosn?schema=public"

# NextAuth.js (optionnel)
# NEXTAUTH_SECRET="votre-secret-tres-long-et-securise"
# NEXTAUTH_URL="http://localhost:3000"

# Pour la production
# NEXTAUTH_URL="https://votre-domaine.vercel.app"
