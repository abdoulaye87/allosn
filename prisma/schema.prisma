// Prisma Schema - AlloSN
// Compatible SQLite (dev) et PostgreSQL (prod)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url      = env("DATABASE_URL")
  
  // Pour PostgreSQL (production), commenter les 2 lignes ci-dessus et décommenter :
  // provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  city      String?
  type      String   @default("particular") // particular or professional
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ads       Ad[]
}

model Category {
  id        String     @id @default(cuid())
  name      String
  icon      String
  slug      String     @unique
  color     String?
  parentId  String?
  parent    Category?  @relation("Subcategories", fields: [parentId], references: [id], onDelete: Cascade)
  children  Category[] @relation("Subcategories")
  ads       Ad[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Ad {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float?
  images      String   @default("[]") // JSON array of image URLs
  city        String
  phone       String?
  whatsapp    String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  views       Int      @default(0)
  isPremium   Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  status      String   @default("active") // active, pending, sold, expired
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([categoryId])
  @@index([city])
  @@index([status])
}

model City {
  id        String   @id @default(cuid())
  name      String   @unique
  region    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  adId      String
  createdAt DateTime @default(now())
  
  @@unique([userId, adId])
}
